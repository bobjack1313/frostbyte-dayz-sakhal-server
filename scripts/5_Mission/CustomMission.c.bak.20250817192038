class CustomMission : MissionServer
{
    // ---- cyclic index persistence ----
    protected int mThemeIndex;

    protected string ThemeIndexPath()
    {
        return "$profile:theme_index.txt";
    }

    protected int LoadThemeIndex()
    {
        int idx = 0;
        FileHandle f = OpenFile(ThemeIndexPath(), FileMode.READ);
        if (f) {
            string s;
            if (FGets(f, s) > 0) { s.Trim(); idx = s.ToInt(); }
            CloseFile(f);
        }
        return idx;
    }

    protected void SaveThemeIndex()
    {
        FileHandle f = OpenFile(ThemeIndexPath(), FileMode.WRITE);
        if (!f) return;
        FPrintln(f, mThemeIndex.ToString());
        CloseFile(f);
    }

    void CustomMission()
    {
        // constructor
        LoadNameCache();
        mThemeIndex = LoadThemeIndex();
    }

    // === RADIO HANDOFF ===
    ref Timer m_RadioTimer;

    override void OnInit()
    {
        super.OnInit();
        GetGame().GetCallQueue(CALL_CATEGORY_SYSTEM).CallLater(RadioSchedulerTick, 2000, true);
        //WeatherService.Start(60.0); // ok if silent for now   
    }

    void RadioSchedulerTick()
    {
        array<string> due = RadioQueue.RunDue();
        if (!due) return;
        foreach (string msg : due) {
            RadioBroadcaster.Broadcast(msg);
        }
    }

    override void OnEvent(EventType eventTypeId, Param params)
    {
        super.OnEvent(eventTypeId, params);

        if (eventTypeId == PlayerDeathEventTypeID)
        {
            Param2<DayZPlayer, Object> p = Param2<DayZPlayer, Object>.Cast(params);
            if (!p) return;

            PlayerBase victim = PlayerBase.Cast(p.param1);
            if (!victim) return;

            string vname = SafeName(victim);
            string vuid  = "NA";
            PlayerIdentity vid = victim.GetIdentity();
            if (vid) vuid = vid.GetPlainId();

            string kname = KillerLabel(p.param2, victim);
            string grid  = GridRef(victim.GetPosition());

            LogRadio(string.Format("DEATH Victim=\"%1\" UID=%2 Killer=\"%3\" Pos=%4", vname, vuid, kname, grid));
        }
        else if (eventTypeId == ClientReadyEventTypeID)
        {
            Param2<PlayerIdentity, PlayerBase> pr = Param2<PlayerIdentity, PlayerBase>.Cast(params);
            if (pr && pr.param1) {
                // write immediately
                SaveNameKV(pr.param1.GetPlainId(), pr.param1.GetName());

                // if initial name is generic, retry once after 5s
                if (pr.param1.GetName() == "Survivor") {
                    string uid_retry = pr.param1.GetPlainId();
                    GetGame().GetCallQueue(CALL_CATEGORY_SYSTEM).CallLater(SaveNameKV, 5000, false, uid_retry, pr.param1.GetName());
                }
            } else {
                ACHLog("[NAMECACHE] ClientReady: no PlayerIdentity found in params");
            }
        }
    }

    void MissionNowTick()
    {
        int now = GetGame().GetTime() / 1000; // seconds since server start
        FileHandle f = OpenFile("$profile:mission_now.txt", FileMode.WRITE);
        if (f) { FPrintln(f, now.ToString()); CloseFile(f); }
    }

    // ---------- Vanilla hooks ----------
    override PlayerBase CreateCharacter(PlayerIdentity identity, vector pos, ParamsReadContext ctx, string characterName)
    {
        Entity playerEnt = GetGame().CreatePlayer(identity, characterName, pos, 0, "NONE");
        Class.CastTo(m_player, playerEnt);
        GetGame().SelectPlayer(identity, m_player);
        return m_player;
    }

